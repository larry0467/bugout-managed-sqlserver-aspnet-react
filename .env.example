# Docker Compose environment variables
# Copy this to .env and fill in your values

# SQL Server SA password
DB_PASSWORD=BugsManaged2026!

# JWT signing secret (min 256 bits / 32 chars)
JWT_SECRET=BugsManaged2026SecretKeyMustBeAtLeast256BitsLong!

# CORS allowed origins (comma-separated)
# Add your app domains here
CORS_ORIGINS=https://bugs.yourdomain.com,https://financials.yourdomain.com,https://hdd.yourdomain.com
