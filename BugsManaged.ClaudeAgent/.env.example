# --- Required ---

# Anthropic API key used by the Agent SDK.
ANTHROPIC_API_KEY=

# Shared secret. Every POST /run request must send `X-Claude-Agent-Key: <this>`.
CLAUDE_AGENT_SIDECAR_API_KEY=

# --- Optional ---

# GitHub token with repo scope. If not set, sidecar runs in analysis-only mode (no PRs).
GITHUB_TOKEN=

# Port the HTTP server listens on. Defaults to 7100.
PORT=7100
